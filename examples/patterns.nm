# Pattern Matching

fn classify_number(n: Int) -> String do
  match n {
    0 => "Zero",
    1 => "One",
    2 => "Two",
    _ => "Many",
  }
end

fn grade_label(score: Int) -> String do
  match score {
    100 => "Perfect",
    90 => "Great",
    80 => "Good",
    _ => "Keep going",
  }
end

fn main() do
  print classify_number(0)
  print classify_number(1)
  print classify_number(42)
  print grade_label(100)
  print grade_label(75)
end
