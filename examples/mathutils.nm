# mathutils.nm - reusable math utilities module

export fn square(x: Int) -> Int do
  x * x
end

export fn cube(x: Int) -> Int do
  x * x * x
end

export fn factorial(n: Int) -> Int do
  if n <= 1 then 1 else n * factorial(n - 1) end
end

export fn abs_val(x: Int) -> Int do
  if x < 0 then -x else x end
end
